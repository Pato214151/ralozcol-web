# Cloudflare Pages — Cache headers
# El HTML nunca se cachea (siempre pide el último)
/*.html
  Cache-Control: no-cache, no-store, must-revalidate

/index.html
  Cache-Control: no-cache, no-store, must-revalidate

# JS y CSS: el browser siempre verifica si cambiaron (no usa versión vieja cacheada)
/js/*
  Cache-Control: no-cache, must-revalidate

/css/*
  Cache-Control: no-cache, must-revalidate
