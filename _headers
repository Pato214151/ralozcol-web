# Cloudflare Pages — Cache headers
# El HTML nunca se cachea (siempre pide el último)
/*.html
  Cache-Control: no-cache, no-store, must-revalidate

/index.html
  Cache-Control: no-cache, no-store, must-revalidate

# JS y CSS se cachean 1 año (el ?v=FECHA en el HTML fuerza la renovación)
/js/*
  Cache-Control: public, max-age=31536000, immutable

/css/*
  Cache-Control: public, max-age=31536000, immutable
